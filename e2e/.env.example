# URL of the running Spring Boot server (no trailing slash)
API_BASE_URL=http://localhost:8080

# Activate the Spring 'test' profile to enable the back-door verification token endpoint.
# Add 'test' to SPRING_PROFILES_ACTIVE in your docker-compose.yml or run config.
# SPRING_PROFILES_ACTIVE=dev,test

# ── MailHog (alternative to back-door endpoint) ─────────────────────────────
# MailHog is already included in docker-compose.yml on port 8025.
# The test suite will fall back to querying MailHog if the back-door endpoint
# is not available.
# MAILHOG_API_URL=http://localhost:8025/api/v2/messages

# ── Mailosaur (optional — for staging environments) ─────────────────────────
# MAILOSAUR_API_KEY=your_key_here
# MAILOSAUR_SERVER_ID=your_server_id_here
